# ============================================================
# paper-tool 环境变量模板
# 用法：
# 1. 复制此文件为 .env
# 2. 按注释填写你实际使用的值
# 3. 不使用的可选项可以留空
# ============================================================

# ============================================================
# 输出后端认证信息
# 详细后端配置见 backends/<name>/backend.yaml
# 也可以让 skill 在运行时自动引导你填写
# ============================================================

# Notion：必填（如果启用 notion 后端）
# 获取方式：到 https://www.notion.so/my-integrations 创建 Integration
# 形如：secret_xxx
NOTION_TOKEN=

# Notion 数据库 ID
# 例如：https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=

# Notion 父页面 ID（自动建库时使用，可选）
NOTION_PARENT_PAGE_ID=

# ============================================================
# LLM 文本任务（必填）
# ============================================================

# 文本模型名称（OpenAI 兼容格式）
OPENAI_MODEL=gpt-4o

# API Key（适用 OpenAI 官方、DeepSeek、Kimi、通义千问等兼容 OpenAI 协议的服务）
OPENAI_API_KEY=

# Base URL（留空 = 官方 api.openai.com）
#   DeepSeek:  https://api.deepseek.com/v1
#   Kimi:      https://api.moonshot.cn/v1
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=

# ============================================================
# LLM 多模态/视觉任务（可选，不填则复用文本任务配置）
# ============================================================

# OPENAI_VISION_MODEL=
# OPENAI_VISION_API_KEY=
# OPENAI_VISION_BASE_URL=

# ============================================================
# OpenReview：可选
# ============================================================

# 某些 OpenReview 论文下载需要登录时使用
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=

# 飞书（Lark）：可选（如果启用 lark 后端）
# 详细配置见 backends/lark/backend.yaml
LARK_IDENTITY=user
LARK_PARENT_FOLDER_TOKEN=
