# ============================================================
# paper-tool 环境变量模板
# 用法：
# 1. 复制此文件为 .env
# 2. 按注释填写你实际使用的值
# 3. 不使用的可选项可以留空
# ============================================================

# ============================================================
# Notion：必填
# ============================================================

# Notion Integration Token
# 获取方式：到 https://www.notion.so/my-integrations 创建 Integration
# 形如：secret_xxx
NOTION_TOKEN=

# Notion 数据库 ID
# 如果你已经有数据库，就填数据库页面 URL 里的那段 32 位 ID
# 例如：
#   https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
# 首次还没建库时可以先留空，跑建库脚本后会自动写回 .env
NOTION_DATABASE_ID=

# Notion 父页面 ID
# 用途：给 scripts/create_notion_db.py 指定“新数据库创建到哪个页面下面”
# 获取方式：打开目标父页面，从页面 URL 里取出 32 位页面 ID
# 如果你只使用已有数据库、不打算自动建库，可以留空
NOTION_PARENT_PAGE_ID=

# ============================================================
# LLM（OpenAI 兼容接口）
# ============================================================

# OpenAI / 兼容接口的 API Key
# 适用：OpenAI 官方、DeepSeek、Kimi、通义千问等兼容 OpenAI 协议的服务
OPENAI_API_KEY=

# OpenAI 兼容接口 Base URL（留空 = 官方 api.openai.com）
# 示例：
#   DeepSeek:  https://api.deepseek.com/v1
#   Kimi:      https://api.moonshot.cn/v1
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=

# ============================================================
# OpenReview：可选
# ============================================================

# 某些 OpenReview 论文下载需要登录时使用
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=
