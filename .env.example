# ============================================================
# paper-tool 环境变量模板
# 用法：
# 1. 复制此文件为 .env
# 2. 按注释填写你实际使用的值
# 3. 不使用的可选项可以留空
# ============================================================

# ============================================================
# Notion：必填
# ============================================================

# Notion Integration Token
# 获取方式：到 https://www.notion.so/my-integrations 创建 Integration
# 形如：secret_xxx
NOTION_TOKEN=

# Notion 数据库 ID
# 如果你已经有数据库，就填数据库页面 URL 里的那段 32 位 ID
# 例如：
#   https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
# 首次还没建库时可以先留空，跑建库脚本后会自动写回 .env
NOTION_DATABASE_ID=

# Notion 父页面 ID
# 用途：给 scripts/create_notion_db.py 指定“新数据库创建到哪个页面下面”
# 获取方式：打开目标父页面，从页面 URL 里取出 32 位页面 ID
# 如果你只使用已有数据库、不打算自动建库，可以留空
NOTION_PARENT_PAGE_ID=

# ============================================================
# LLM：至少填写一组可用提供商
# ============================================================

# OpenAI / OpenAI 兼容接口的 API Key
# 适用于官方 OpenAI，也适用于很多兼容 OpenAI 协议的服务
OPENAI_API_KEY=

# OpenAI 兼容接口 Base URL
# 留空表示使用官方 api.openai.com
# 如果你用 DeepSeek / Kimi / 通义千问 / 本地 vLLM 等兼容接口，需要填写这里
# 示例：
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_BASE_URL=

# Anthropic API Key
# 当 llm.model 使用 anthropic/* 时需要
ANTHROPIC_API_KEY=

# Gemini API Key
# 当 llm.model 使用 gemini/* 时需要
GEMINI_API_KEY=

# ============================================================
# OpenReview：可选
# ============================================================

# 某些 OpenReview 论文下载需要登录时使用
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=
