# ============================================================
# API Keys - 复制此文件为 .env 并填入你的密钥
# ============================================================

# Notion Integration Token
# 在 https://www.notion.so/my-integrations 创建
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 数据库 ID
# 从数据库页面 URL 中提取：https://notion.so/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM API Keys（根据你使用的模型填写对应的 key）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 自定义 OpenAI 兼容端点（留空则使用官方 api.openai.com）
# 适用于 Kimi、DeepSeek、通义千问、vLLM 等兼容 OpenAI 协议的服务
# 例：OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenReview 账号（可选，用于需要认证才能下载的论文）
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=
